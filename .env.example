AIMAC_PORT=4317
AIMAC_HOST=0.0.0.0
AIMAC_RUNTIME_DIR=.runtime
AIMAC_REPOSITORY_ROOT=.
AIMAC_EXECUTION_PROFILE=production
AIMAC_PUBLIC_URL=http://127.0.0.1:4317
AIMAC_TRUST_PROXY=false
AIMAC_STATE_STORE=runtime_json
AIMAC_MCP_CONFIG_DIR=.runtime/mcp-client-configs
AIMAC_SYSTEM_ADMIN_EMAIL=system.admin@local
AIMAC_SYSTEM_ADMIN_NAME=System Owner
# Use long random values when setting these locally. Leave commented for first-run local defaults.
# scripts/docker-up.sh generates and persists local Docker values automatically when these are unset.
# AIMAC_BOOTSTRAP_TOKEN=
# AIMAC_MCP_SERVICE_TOKEN=
# AIMAC_LOCAL_SEED_WORKSPACE_OWNER_TOKEN=
# AIMAC_LOCAL_SEED_REVIEWER_TOKEN=
# AIMAC_LOCAL_SEED_AGENT_RUNTIME_TOKEN=
AIMAC_AGENT_RUNTIME_EXECUTOR_COMMAND=
AIMAC_ALLOW_LOCAL_DETERMINISTIC_WORKER=false
AIMAC_ALLOW_INSECURE_REMOTE_MCP=false
# Performance / hardening knobs (defaults shown; uncomment to override).
# AIMAC_KEEP_ALIVE_TIMEOUT_MS=65000
# AIMAC_REQUEST_TIMEOUT_MS=300000
# AIMAC_LOGIN_ATTEMPTS_PER_MINUTE=10
# AIMAC_HEARTBEAT_PERSIST_FLOOR_MS=120000
# AIMAC_RUNTIME_JSON_PRETTY=false
# AIMAC_PROJECT_EVENT_IDEMPOTENCY_KEYS=500
# AIMAC_AGENT_REQUEST_TIMEOUT_MS=30000
# AIMAC_AGENT_EXECUTION_KEEPALIVE_MS=60000
# POSTGRES_PASSWORD=
DATABASE_URL=postgres://aimac:aimac@localhost:55432/aimac
