{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dleno.local/spec/checkpoint.schema.json",
  "title": "Checkpoint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "projectId",
    "taskGroupId",
    "workId",
    "sessionId",
    "runId",
    "stateVersion",
    "summary",
    "nextSteps",
    "openMachineActionIds",
    "derivedWorkRequests",
    "returnPointRef",
    "commitRefs",
    "pushRefs",
    "repositoryOutputTargetRefs",
    "artifactManifestRefs",
    "changedPathEvidenceRefs",
    "evidenceRefs",
    "outputContractDigest",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "checkpoint/v1"
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "taskGroupId": {
      "type": "string",
      "minLength": 1
    },
    "workId": {
      "type": "string",
      "minLength": 1
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "stateVersion": {
      "type": "integer",
      "minimum": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "nextSteps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["actionId", "mode", "summary", "evidenceRefs"],
        "properties": {
          "actionId": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "enum": ["current_absorb", "preempt_current", "after_current", "scheduled_after", "backlog", "none"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "evidenceRefs": {
            "$ref": "#/$defs/refArray"
          }
        }
      }
    },
    "openMachineActionIds": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "derivedWorkRequests": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "returnPointRef": {
      "type": "string",
      "minLength": 1
    },
    "commitRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "commit-ref.schema.json"
      }
    },
    "pushRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "push-ref.schema.json"
      }
    },
    "repositoryOutputTargetRefs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifactManifestRefs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "changedPathEvidenceRefs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "outputContractDigest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "refArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
