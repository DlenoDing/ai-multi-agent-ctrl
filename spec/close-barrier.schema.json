{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dleno.local/spec/close-barrier.schema.json",
  "title": "CloseBarrier",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "projectId",
    "taskGroupId",
    "stateVersion",
    "stateDigest",
    "sourceQueryRefs",
    "requiredGates",
    "gateResults",
    "blockingObjects",
    "evidenceRefs",
    "computedAt",
    "satisfied"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "close-barrier/v1"
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "taskGroupId": {
      "type": "string",
      "minLength": 1
    },
    "stateVersion": {
      "type": "integer",
      "minimum": 1
    },
    "stateDigest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "sourceQueryRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["queryId", "source", "digest"],
        "properties": {
          "queryId": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "type": "string",
            "pattern": "^sha256:[a-fA-F0-9]{64}$"
          }
        }
      }
    },
    "requiredGates": {
      "type": "array",
      "minItems": 27,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/closeGate"
      }
    },
    "gateResults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_required_work_closed",
        "all_findings_terminal",
        "all_quality_gates_passed",
        "all_contracts_compatible",
        "all_changes_integrated",
        "no_pending_permissions",
        "no_pending_approvals",
        "all_policy_decisions_terminal",
        "all_commands_terminal",
        "all_command_effects_terminal",
        "no_active_dlq",
        "all_leases_terminal",
        "no_active_temp_grants",
        "no_active_secret_leases",
        "no_open_external_capability_boundaries",
        "artifacts_verified",
        "release_manifest_ready",
        "rules_candidates_processed",
        "runtime_issue_candidates_exported",
        "no_open_execution_topologies",
        "no_blocking_derived_task_requests",
        "all_review_plans_closed",
        "no_pending_review_bundles",
        "all_rule_sources_resolved",
        "completion_readiness_clear",
        "no_active_role_drift_blockers",
        "all_effective_instruction_packets_terminal"
      ],
      "properties": {
        "all_required_work_closed": {"$ref": "#/$defs/gateResult"},
        "all_findings_terminal": {"$ref": "#/$defs/gateResult"},
        "all_quality_gates_passed": {"$ref": "#/$defs/gateResult"},
        "all_contracts_compatible": {"$ref": "#/$defs/gateResult"},
        "all_changes_integrated": {"$ref": "#/$defs/gateResult"},
        "no_pending_permissions": {"$ref": "#/$defs/gateResult"},
        "no_pending_approvals": {"$ref": "#/$defs/gateResult"},
        "all_policy_decisions_terminal": {"$ref": "#/$defs/gateResult"},
        "all_commands_terminal": {"$ref": "#/$defs/gateResult"},
        "all_command_effects_terminal": {"$ref": "#/$defs/gateResult"},
        "no_active_dlq": {"$ref": "#/$defs/gateResult"},
        "all_leases_terminal": {"$ref": "#/$defs/gateResult"},
        "no_active_temp_grants": {"$ref": "#/$defs/gateResult"},
        "no_active_secret_leases": {"$ref": "#/$defs/gateResult"},
        "no_open_external_capability_boundaries": {"$ref": "#/$defs/gateResult"},
        "artifacts_verified": {"$ref": "#/$defs/gateResult"},
        "release_manifest_ready": {"$ref": "#/$defs/gateResult"},
        "rules_candidates_processed": {"$ref": "#/$defs/gateResult"},
        "runtime_issue_candidates_exported": {"$ref": "#/$defs/gateResult"},
        "no_open_execution_topologies": {"$ref": "#/$defs/gateResult"},
        "no_blocking_derived_task_requests": {"$ref": "#/$defs/gateResult"},
        "all_review_plans_closed": {"$ref": "#/$defs/gateResult"},
        "no_pending_review_bundles": {"$ref": "#/$defs/gateResult"},
        "all_rule_sources_resolved": {"$ref": "#/$defs/gateResult"},
        "completion_readiness_clear": {"$ref": "#/$defs/gateResult"},
        "no_active_role_drift_blockers": {"$ref": "#/$defs/gateResult"},
        "all_effective_instruction_packets_terminal": {"$ref": "#/$defs/gateResult"}
      }
    },
    "blockingObjects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["objectType", "objectId", "status"],
        "properties": {
          "objectType": {
            "type": "string",
            "enum": [
              "WorkItem",
              "Finding",
              "QualityGate",
              "Contract",
              "IntegrationBatch",
              "ReleaseManifest",
              "PermissionRequest",
              "ApprovalRequest",
              "PolicyDecision",
              "Command",
              "CommandEffect",
              "DLQEntry",
              "Lease",
              "TempGrant",
              "SecretLease",
              "SecretGrant",
              "ExternalCapabilityBoundary",
              "ExecutionTopology",
              "DerivedTaskRequest",
              "ReviewPlan",
              "ReviewBundle",
              "RuleSourceResolution",
              "CompletionReadinessCheck",
              "EffectiveInstructionPacket",
              "RoleDriftGuard",
              "Ruleset",
              "RuntimeIssuePattern",
              "SystemUpgradeCandidate",
              "Artifact"
            ]
          },
          "objectId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      }
    },
    "waivers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate", "decisionRecordRef", "expiresAt"],
        "properties": {
          "gate": {
            "type": "string"
          },
          "decisionRecordRef": {
            "type": "string",
            "minLength": 1
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "default": []
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "computedAt": {
      "type": "string",
      "format": "date-time"
    },
    "satisfied": {
      "type": "boolean"
    }
  },
  "allOf": [
    {
      "properties": {
        "requiredGates": {
          "allOf": [
            {"contains": {"const": "all_required_work_closed"}},
            {"contains": {"const": "all_findings_terminal"}},
            {"contains": {"const": "all_quality_gates_passed"}},
            {"contains": {"const": "all_contracts_compatible"}},
            {"contains": {"const": "all_changes_integrated"}},
            {"contains": {"const": "no_pending_permissions"}},
            {"contains": {"const": "no_pending_approvals"}},
            {"contains": {"const": "all_policy_decisions_terminal"}},
            {"contains": {"const": "all_commands_terminal"}},
            {"contains": {"const": "all_command_effects_terminal"}},
            {"contains": {"const": "no_active_dlq"}},
            {"contains": {"const": "all_leases_terminal"}},
            {"contains": {"const": "no_active_temp_grants"}},
            {"contains": {"const": "no_active_secret_leases"}},
            {"contains": {"const": "no_open_external_capability_boundaries"}},
            {"contains": {"const": "artifacts_verified"}},
            {"contains": {"const": "release_manifest_ready"}},
            {"contains": {"const": "rules_candidates_processed"}},
            {"contains": {"const": "runtime_issue_candidates_exported"}},
            {"contains": {"const": "no_open_execution_topologies"}},
            {"contains": {"const": "no_blocking_derived_task_requests"}},
            {"contains": {"const": "all_review_plans_closed"}},
            {"contains": {"const": "no_pending_review_bundles"}},
            {"contains": {"const": "all_rule_sources_resolved"}},
            {"contains": {"const": "completion_readiness_clear"}},
            {"contains": {"const": "no_active_role_drift_blockers"}},
            {"contains": {"const": "all_effective_instruction_packets_terminal"}}
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "satisfied": {
            "const": true
          }
        },
        "required": ["satisfied"]
      },
      "then": {
        "properties": {
          "blockingObjects": {
            "maxItems": 0
          },
          "gateResults": {
            "patternProperties": {
              ".*": {
              "properties": {
                "status": {
                  "const": "passed"
                }
              },
              "required": ["status"]
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "closeGate": {
      "type": "string",
      "enum": [
        "all_required_work_closed",
        "all_findings_terminal",
        "all_quality_gates_passed",
        "all_contracts_compatible",
        "all_changes_integrated",
        "no_pending_permissions",
        "no_pending_approvals",
        "all_policy_decisions_terminal",
        "all_commands_terminal",
        "all_command_effects_terminal",
        "no_active_dlq",
        "all_leases_terminal",
        "no_active_temp_grants",
        "no_active_secret_leases",
        "no_open_external_capability_boundaries",
        "artifacts_verified",
        "release_manifest_ready",
        "rules_candidates_processed",
        "runtime_issue_candidates_exported",
        "no_open_execution_topologies",
        "no_blocking_derived_task_requests",
        "all_review_plans_closed",
        "no_pending_review_bundles",
        "all_rule_sources_resolved",
        "completion_readiness_clear",
        "no_active_role_drift_blockers",
        "all_effective_instruction_packets_terminal"
      ]
    },
    "gateResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "evidenceRefs"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "blocked"]
        },
        "evidenceRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "reasonCode": {
          "type": "string"
        }
      }
    }
  }
}
