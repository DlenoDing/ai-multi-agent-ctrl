{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dleno.local/spec/commit-ref.schema.json",
  "title": "CommitRef",
  "type": "object",
  "additionalProperties": false,
  "required": ["repo", "branch", "commit", "treeDigest", "createdAt"],
  "properties": {
    "repo": {
      "type": "string",
      "minLength": 1
    },
    "branch": {
      "type": "string",
      "minLength": 1
    },
    "commit": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{7,64}$"
    },
    "treeDigest": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
