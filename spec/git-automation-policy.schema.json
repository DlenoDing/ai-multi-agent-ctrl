{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dleno.local/spec/git-automation-policy.schema.json",
  "title": "GitAutomationPolicy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "repositoryId",
    "credentialProfileRef",
    "credentialGrantRef",
    "expiresAt",
    "allowedActions",
    "baseRef",
    "workBranch",
    "commitPolicy",
    "pushPolicy",
    "changedPathPolicy"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "git-automation-policy/v1"
    },
    "repositoryId": {
      "type": "string",
      "minLength": 1
    },
    "remoteName": {
      "type": "string",
      "default": "origin"
    },
    "credentialProfileRef": {
      "type": "string",
      "minLength": 1
    },
    "credentialGrantRef": {
      "type": "string",
      "minLength": 1
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "allowedActions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["fetch", "status", "commit", "push", "tag", "merge_queue_submit"]
      }
    },
    "baseRef": {
      "type": "string",
      "minLength": 1
    },
    "workBranch": {
      "type": "string",
      "pattern": "^(tg|work|agent)/.+"
    },
    "commitPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authorIdentityRef", "messageTemplate", "requireSignedCommit"],
      "properties": {
        "authorIdentityRef": {
          "type": "string"
        },
        "messageTemplate": {
          "type": "string",
          "minLength": 1
        },
        "requireSignedCommit": {
          "type": "boolean"
        }
      }
    },
    "pushPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetRef", "allowedTargetRefPatterns", "forbidForcePush", "verifyRemoteSha", "nonFastForward", "retryPolicy", "dlqPolicyRef"],
      "properties": {
        "targetRef": {
          "type": "string",
          "minLength": 1
        },
        "allowedTargetRefPatterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidForcePush": {
          "type": "boolean",
          "const": true
        },
        "verifyRemoteSha": {
          "type": "boolean",
          "const": true
        },
        "nonFastForward": {
          "type": "string",
          "enum": ["reject_and_rebase_batch", "reject_to_dlq"]
        },
        "retryPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxAttempts", "backoff", "maxRetryWindow", "retryableErrorClasses"],
          "properties": {
            "maxAttempts": {
              "type": "integer",
              "minimum": 2
            },
            "backoff": {
              "type": "string",
              "enum": ["fixed", "exponential"]
            },
            "maxRetryWindow": {
              "type": "string",
              "minLength": 1
            },
            "retryableErrorClasses": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": ["network", "remote_transient", "credential_refreshable", "lock_contention"]
              }
            }
          }
        },
        "dlqPolicyRef": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "changedPathPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mustMatchWriteScope", "allowGeneratedFiles", "allowLockfileChanges", "allowDeletes", "allowRenames"],
      "properties": {
        "mustMatchWriteScope": {
          "type": "boolean",
          "const": true
        },
        "allowGeneratedFiles": {
          "type": "boolean"
        },
        "allowLockfileChanges": {
          "type": "boolean"
        },
        "allowDeletes": {
          "type": "boolean"
        },
        "allowRenames": {
          "type": "boolean"
        },
        "extraAllowedPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    }
  }
}
