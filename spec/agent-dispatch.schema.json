{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dleno.local/spec/agent-dispatch.schema.json",
  "title": "AgentDispatch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "dispatchId",
    "projectId",
    "taskGroupId",
    "workItemId",
    "sessionId",
    "runId",
    "status",
    "deliveryMode",
    "model",
    "reasoning",
    "modelDecision",
    "modelSelectionDecisionRef",
    "taskContractDigest",
    "taskContractRef",
    "repositoryOutputTargetRef",
    "roleId",
    "skillWorksetId",
    "requiredCredentialEnvNames",
    "workerKind",
    "attempts",
    "checkpointRequired",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {"type": "string", "const": "agent-dispatch/v1"},
    "dispatchId": {"type": "string", "minLength": 1},
    "projectId": {"type": "string", "minLength": 1},
    "taskGroupId": {"type": "string", "minLength": 1},
    "workItemId": {"type": "string", "minLength": 1},
    "sessionId": {"type": "string", "minLength": 1},
    "runId": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["queued", "running", "blocked", "completed", "failed", "cancelled"]},
    "deliveryMode": {"type": "string", "enum": ["new_session", "subagent"]},
    "model": {"type": "string", "minLength": 1},
    "reasoning": {"type": "string", "minLength": 1},
    "modelDecision": {"type": "string", "minLength": 1, "maxLength": 240},
    "modelSelectionDecisionRef": {"type": "string", "minLength": 1},
    "taskContractDigest": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
    "taskContractRef": {"type": "string", "minLength": 1},
    "repositoryOutputTargetRef": {"type": "string", "minLength": 1},
    "roleId": {"type": "string", "minLength": 1},
    "skillWorksetId": {"type": "string", "pattern": "^skillset_[a-fA-F0-9]{24}$"},
    "requiredCredentialEnvNames": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "workerKind": {"type": "string", "enum": ["model_agent_runtime", "local_deterministic_worker"]},
    "attempts": {"type": "integer", "minimum": 0},
    "checkpointRequired": {"type": "boolean", "const": true},
    "blockedReason": {"type": "string"},
    "failureReason": {"type": "string"},
    "checkpointRef": {"type": "string"},
    "assignedNodeId": {"type": "string", "minLength": 1},
    "claimedAt": {"type": "string", "format": "date-time"},
    "claimExpiresAt": {"type": "string", "format": "date-time"},
    "controlCommandRef": {"type": "string", "minLength": 1},
    "controlRequestedAt": {"type": "string", "format": "date-time"},
    "progressPercent": {"type": "integer", "minimum": 0, "maximum": 100},
    "lastExecutionEventRef": {"type": "string", "minLength": 1},
    "lastExecutionEventAt": {"type": "string", "format": "date-time"},
    "createdAt": {"type": "string", "format": "date-time"},
    "updatedAt": {"type": "string", "format": "date-time"},
    "completedAt": {"type": "string", "format": "date-time"}
  }
}
