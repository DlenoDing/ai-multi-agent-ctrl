{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dleno.local/spec/mcp-grant.schema.json",
  "title": "McpGrant",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "grantId",
    "serverId",
    "toolName",
    "schemaDigest",
    "riskLevel",
    "paramPolicyRef",
    "resultFilterRef",
    "expiresAt"
  ],
  "properties": {
    "grantId": {
      "type": "string",
      "minLength": 1
    },
    "serverId": {
      "type": "string",
      "minLength": 1
    },
    "toolName": {
      "type": "string",
      "minLength": 1
    },
    "schemaDigest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "riskLevel": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L3"]
    },
    "paramPolicyRef": {
      "type": "string",
      "minLength": 1
    },
    "resultFilterRef": {
      "type": "string",
      "minLength": 1
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
