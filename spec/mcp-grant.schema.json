{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dleno.local/spec/mcp-grant.schema.json",
  "title": "McpGrant",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "grantId",
    "projectId",
    "taskGroupId",
    "workId",
    "sessionId",
    "agentNodeId",
    "serverId",
    "toolName",
    "resource",
    "action",
    "schemaDigest",
    "policyDecisionRef",
    "approvalRequestRef",
    "riskLevel",
    "paramPolicyRef",
    "paramPolicyDigest",
    "resultFilterRef",
    "resultFilterDigest",
    "leaseRef",
    "idempotencyKey",
    "issuedAt",
    "expiresAt",
    "maxTtl",
    "grantStatus",
    "revocationRef",
    "auditRef",
    "grantDigest"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "mcp-grant/v1"
    },
    "grantId": {
      "type": "string",
      "minLength": 1
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "taskGroupId": {
      "type": "string",
      "minLength": 1
    },
    "workId": {
      "type": "string",
      "minLength": 1
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "dispatchId": {
      "type": "string",
      "minLength": 1
    },
    "roleId": {
      "type": "string",
      "minLength": 1
    },
    "principalRef": {
      "type": "string",
      "minLength": 1
    },
    "agentNodeId": {
      "type": "string",
      "minLength": 1
    },
    "serverId": {
      "type": "string",
      "minLength": 1
    },
    "endpointPath": {
      "type": "string",
      "minLength": 1
    },
    "transport": {
      "type": "string",
      "minLength": 1
    },
    "toolName": {
      "type": "string",
      "minLength": 1
    },
    "resource": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "schemaDigest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "policyDecisionRef": {
      "type": "string",
      "minLength": 1
    },
    "approvalRequestRef": {
      "type": "string",
      "minLength": 1
    },
    "riskLevel": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L3"]
    },
    "paramPolicyRef": {
      "type": "string",
      "minLength": 1
    },
    "paramPolicyDigest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "resultFilterRef": {
      "type": "string",
      "minLength": 1
    },
    "resultFilterDigest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "leaseRef": {
      "type": "string",
      "minLength": 1
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "maxTtl": {
      "type": "string",
      "minLength": 1
    },
    "grantStatus": {
      "type": "string",
      "enum": ["issued", "revoked", "expired"]
    },
    "revocationRef": {
      "type": "string",
      "minLength": 1
    },
    "auditRef": {
      "type": "string",
      "minLength": 1
    },
    "grantDigest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
