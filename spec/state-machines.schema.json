{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dleno.local/spec/state-machines.schema.json",
  "title": "StateMachinesSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "machines"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "state-machines/v1"
    },
    "machines": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["initial", "terminal", "states", "transitions"],
        "properties": {
          "initial": {
            "type": "string"
          },
          "terminal": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "states": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "transitions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["from", "to", "actor", "requires"],
              "properties": {
                "from": {
                  "type": "string"
                },
                "to": {
                  "type": "string"
                },
                "actor": {
                  "type": "string"
                },
                "requires": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
