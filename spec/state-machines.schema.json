{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dleno.local/spec/state-machines.schema.json",
  "title": "StateMachinesSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "gateCatalogRef", "gateResolutionPolicy", "machines"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "state-machines/v1"
    },
    "gateCatalogRef": {
      "type": "string",
      "minLength": 1
    },
    "gateResolutionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unresolvedGate", "resolverSelection"],
      "properties": {
        "unresolvedGate": {
          "type": "string",
          "const": "reject_transition"
        },
        "resolverSelection": {
          "type": "string",
          "enum": ["first_matching_specificity", "exact_id_only"]
        }
      }
    },
    "machines": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["initial", "terminal", "states", "transitions"],
        "properties": {
          "initial": {
            "type": "string"
          },
          "terminal": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "states": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "transitions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["from", "to", "actor", "requires"],
              "properties": {
                "from": {
                  "type": "string"
                },
                "to": {
                  "type": "string"
                },
                "actor": {
                  "type": "string",
                  "enum": [
                    "orchestrator",
                    "decision-center",
                    "scheduler",
                    "work-session",
                    "reviewer",
                    "qa",
                    "security",
                    "release",
                    "rule-steward",
                    "monitor",
                    "agent-runtime",
                    "command-bus",
                    "permission-gateway",
                    "policy-engine",
                    "mcp-proxy",
                    "room-broker",
                    "model-registry",
                    "skill-registry"
                  ]
                },
                "requires": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
