{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dleno.local/spec/access-control-grant.schema.json",
  "title": "AccessControlGrant",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "grantId", "status", "subjectRef", "resource", "role", "permissions", "policyDecisionRef", "createdAt", "updatedAt"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "access-control-grant/v1"
    },
    "grantId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["requested", "policy_checked", "active", "suspended", "revoked", "expired"]
    },
    "subjectRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subjectType", "subjectId"],
      "properties": {
        "subjectType": {"type": "string", "enum": ["account", "service", "agent_identity"]},
        "subjectId": {"type": "string", "minLength": 1}
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resourceType", "resourceId"],
      "properties": {
        "resourceType": {
          "type": "string",
          "enum": ["system_console", "user_console", "project", "task_group", "agent", "system_policy", "shared_definition"]
        },
        "resourceId": {"type": "string", "minLength": 1}
      }
    },
    "role": {
      "type": "string",
      "enum": [
        "system_owner",
        "system_admin",
        "system_auditor",
        "workspace_owner",
        "project_owner",
        "project_admin",
        "task_group_owner",
        "agent_operator",
        "reviewer",
        "viewer"
      ]
    },
    "permissions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "scopeDigest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "policyDecisionRef": {
      "type": "string",
      "minLength": 1
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "auditRef": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
