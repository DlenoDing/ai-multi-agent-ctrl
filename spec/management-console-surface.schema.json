{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dleno.local/spec/management-console-surface.schema.json",
  "title": "ManagementConsoleSurface",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "surfaceId", "consoleType", "status", "route", "views", "guardedActions", "visualQualityGates", "createdAt", "updatedAt"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "management-console-surface/v1"
    },
    "surfaceId": {
      "type": "string",
      "minLength": 1
    },
    "consoleType": {
      "type": "string",
      "enum": ["system_management", "user_management"]
    },
    "status": {
      "type": "string",
      "enum": ["drafted", "validated", "active", "disabled", "retired"]
    },
    "route": {
      "type": "string",
      "minLength": 1
    },
    "views": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["runtime", "accounts", "audit", "policies", "projects", "task_groups", "agents", "permissions", "progress", "instructions"]
      }
    },
    "guardedActions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["actionId", "riskClass", "requiredPermission", "decisionRequired"],
        "properties": {
          "actionId": {"type": "string", "minLength": 1},
          "riskClass": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
          "requiredPermission": {"type": "string", "minLength": 1},
          "decisionRequired": {"type": "boolean"}
        }
      }
    },
    "visualQualityGates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["responsive_layout", "text_no_overlap", "action_state_visible", "progress_visible", "audit_trace_visible"]
      }
    },
    "auditRef": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
