{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dleno.local/spec/control-events.schema.json",
  "title": "ControlEventEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "protocolVersion",
    "schemaDigest",
    "eventId",
    "projectId",
    "type",
    "actor",
    "subject",
    "stateVersion",
    "idempotencyKey",
    "createdAt"
  ],
  "anyOf": [
    {
      "required": ["payload"]
    },
    {
      "required": ["payloadRef", "payloadDigest"]
    }
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "control-event/v1"
    },
    "protocolVersion": {
      "type": "string",
      "const": "control-plane/v1"
    },
    "schemaDigest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "taskGroupId": {
      "type": "string"
    },
    "roomId": {
      "type": "string"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "sender": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sessionId": {
          "type": "string"
        },
        "roleId": {
          "type": "string"
        },
        "agentNodeId": {
          "type": "string"
        }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actorType", "actorId"],
      "properties": {
        "actorType": {
          "type": "string",
          "enum": ["role", "session", "agent_node", "service"]
        },
        "actorId": {
          "type": "string"
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "Project",
            "TaskGroup",
            "WorkItem",
            "WorkSession",
            "AgentNode",
            "Room",
            "RoomMessage",
            "Command",
            "CommandEffect",
            "Lease",
            "Checkpoint",
            "Artifact",
            "Finding",
            "Contract",
            "IntegrationBatch",
            "PermissionRequest",
            "ApprovalRequest",
            "DecisionRecord",
            "AuditLog",
            "Alert",
            "Ruleset",
            "PolicyDecision",
            "QualityGate",
            "ChangeSet",
            "MergeQueueItem",
            "ReleaseManifest",
            "DLQEntry",
            "SecretGrant",
            "SecretLease",
            "TempGrant",
            "ExternalCapabilityBoundary",
            "AgentSkillSource",
            "AgentRoleSkill",
            "RoleSkillOverlay",
            "ModelProvider",
            "ModelCapabilityProfile",
            "ModelSelectionPolicy",
            "ModelSelectionDecision",
            "SessionPlacementPolicy",
            "SessionPlacementDecision",
            "EffectiveInstructionPacket",
            "RoleDriftGuard",
            "ExecutionTopology",
            "DerivedTaskRequest",
            "ReviewPlan",
            "ReviewBundle",
            "RuleSourceResolution",
            "CompletionReadinessCheck",
            "RuntimeIssuePattern",
            "SystemUpgradeCandidate",
            "RuntimeBootstrapProfile",
            "Account",
            "AccessControlGrant",
            "ManagementConsoleSurface",
            "ProgressSnapshot",
            "InstructionEnvelope",
            "SharedDefinitionContract",
            "RepositoryOutputTarget"
          ]
        },
        "id": {
          "type": "string"
        }
      }
    },
    "recipients": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "type": {
      "type": "string",
      "enum": [
        "command",
        "command_created",
        "command_succeeded",
        "delta",
        "checkpoint",
        "checkpoint_submitted",
        "finding",
        "decision",
        "decision_request",
        "review_request",
        "review_result",
        "handoff",
        "blocker",
        "progress",
        "wake",
        "permission_required",
        "permission_resolution",
        "approval_request",
        "approval_decision",
        "contract_proposed",
        "contract_published",
        "integration_batch",
        "command_effect",
        "close_candidate",
        "spec_drift",
        "model_selection_decision",
        "session_placement_decision",
        "effective_instruction_packet",
        "role_drift_guard",
        "execution_topology",
        "derived_task_request",
        "review_plan",
        "review_bundle",
        "rule_source_resolution",
        "completion_readiness",
        "external_capability_boundary",
        "system_upgrade_import",
        "runtime_bootstrap",
        "account_lifecycle",
        "access_control_grant",
        "management_console_surface",
        "progress_snapshot",
        "instruction_envelope",
        "shared_definition_contract",
        "repository_output_target"
      ]
    },
    "priority": {
      "type": "string",
      "enum": ["normal", "important", "p0"],
      "default": "normal"
    },
    "stateVersion": {
      "type": "integer",
      "minimum": 1
    },
    "correlationId": {
      "type": "string"
    },
    "causationId": {
      "type": "string"
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "payloadSchemaRef": {
      "type": "string",
      "minLength": 1
    },
    "payloadRef": {
      "type": "string"
    },
    "payloadDigest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "stateTransition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["machine", "fromState", "toState", "stateVersionBefore", "stateVersionAfter", "transitionId"],
      "properties": {
        "machine": {
          "type": "string"
        },
        "fromState": {
          "type": "string"
        },
        "toState": {
          "type": "string"
        },
        "stateVersionBefore": {
          "type": "integer",
          "minimum": 1
        },
        "stateVersionAfter": {
          "type": "integer",
          "minimum": 1
        },
        "transitionId": {
          "type": "string"
        }
      }
    },
    "guardEvidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "allOf": [
    {
      "anyOf": [
        {
          "required": ["payloadSchemaRef", "payload"]
        },
        {
          "required": ["payloadSchemaRef", "payloadRef", "payloadDigest"]
        }
      ]
    },
    {
      "if": {
        "required": ["stateTransition"]
      },
      "then": {
        "required": ["guardEvidenceRefs"],
        "properties": {
          "guardEvidenceRefs": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
