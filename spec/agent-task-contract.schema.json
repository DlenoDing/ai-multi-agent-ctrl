{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dleno.local/spec/agent-task-contract.schema.json",
  "title": "AgentTaskContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "projectId",
    "taskGroupId",
    "commandId",
    "sessionId",
    "runId",
    "idempotencyKey",
    "protocolVersion",
    "schemaDigest",
    "contractDigest",
    "issuedAt",
    "expiresAt",
    "taskId",
    "workId",
    "roleId",
    "roleSkill",
    "roomId",
    "placementDecisionRef",
    "stateVersion",
    "rulesetDigest",
    "effectiveInstructionPacketRef",
    "digestRefs",
    "sharedDefinitionRefs",
    "actionBasis",
    "roleFocus",
    "inputLocators",
    "inputDigests",
    "writeScope",
    "repositoryOutputTargetRef",
    "repositoryOutputTargetDigest",
    "artifactManifestPath",
    "model",
    "permissionPolicy",
    "stopOrReturn",
    "outputContract"
  ],
  "properties": {
    "contractVersion": {
      "type": "string",
      "const": "agent-task-contract/v1"
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "taskGroupId": {
      "type": "string",
      "minLength": 1
    },
    "commandId": {
      "type": "string",
      "minLength": 1
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    },
    "protocolVersion": {
      "type": "string",
      "minLength": 1
    },
    "schemaDigest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "contractDigest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "workId": {
      "type": "string",
      "minLength": 1
    },
    "roleId": {
      "type": "string",
      "minLength": 1
    },
    "roleSkill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roleSkillRef",
        "roleSkillDigest",
        "selectedAgentSkillRef",
        "sourceId",
        "overlayRefs",
        "worksetId",
        "synchronizationMode",
        "usageDirective",
        "modelSelectionDecisionRef"
      ],
      "properties": {
        "roleSkillRef": {
          "type": "string",
          "minLength": 1
        },
        "roleSkillDigest": {
          "type": "string",
          "pattern": "^sha256:[a-fA-F0-9]{64}$"
        },
        "selectedAgentSkillRef": {
          "type": "string",
          "minLength": 1
        },
        "sourceId": {
          "type": "string",
          "minLength": 1
        },
        "overlayRefs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "worksetId": {
          "type": "string",
          "pattern": "^skillset_[a-fA-F0-9]{24}$"
        },
        "synchronizationMode": {
          "type": "string",
          "const": "server_managed_on_demand"
        },
        "usageDirective": {
          "type": "string",
          "minLength": 1
        },
        "modelSelectionDecisionRef": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "roomId": {
      "type": "string",
      "minLength": 1
    },
    "placementDecisionRef": {
      "type": "string",
      "minLength": 1
    },
    "stateVersion": {
      "type": "integer",
      "minimum": 1
    },
    "rulesetDigest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "effectiveInstructionPacketRef": {
      "type": "string",
      "minLength": 1
    },
    "digestRefs": {
      "$ref": "#/$defs/refArray"
    },
    "sharedDefinitionRefs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/sharedDefinitionRef"
      }
    },
    "actionBasis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effectiveInstructionPacketRef",
        "sourceKind",
        "sourceRef",
        "nextActionDraftDigest",
        "activeRuleRefs",
        "nonActiveMaterialRefs",
        "contextIntakeRefs",
        "validationRequirements",
        "forbiddenActions",
        "deferredDecisions"
      ],
      "properties": {
        "effectiveInstructionPacketRef": {
          "type": "string",
          "minLength": 1
        },
        "sourceKind": {
          "type": "string",
          "enum": ["user_objective", "orchestrator_plan", "decision_record", "review_advisory", "tool_result", "rule_source_resolution"]
        },
        "sourceRef": {
          "type": "string",
          "minLength": 1
        },
        "nextActionDraftDigest": {
          "type": "string",
          "pattern": "^sha256:[a-fA-F0-9]{64}$"
        },
        "activeRuleRefs": {
          "$ref": "#/$defs/refArray"
        },
        "nonActiveMaterialRefs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["materialRef", "classification"],
            "properties": {
              "materialRef": {
                "type": "string",
                "minLength": 1
              },
              "classification": {
                "type": "string",
                "enum": ["reference_only", "advisory", "history", "test_fixture", "excluded"]
              }
            }
          }
        },
        "contextIntakeRefs": {
          "$ref": "#/$defs/refArray"
        },
        "validationRequirements": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbiddenActions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "deferredDecisions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "roleFocus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roleDriftGuardRef",
        "objectiveBoundaryDigest",
        "roleMissionDigest",
        "taskContractDigest",
        "allowedActionScopeRefs",
        "forbiddenActionScopeRefs",
        "maxAllowedDriftScore"
      ],
      "properties": {
        "roleDriftGuardRef": {
          "type": "string",
          "minLength": 1
        },
        "objectiveBoundaryDigest": {
          "type": "string",
          "pattern": "^sha256:[a-fA-F0-9]{64}$"
        },
        "roleMissionDigest": {
          "type": "string",
          "pattern": "^sha256:[a-fA-F0-9]{64}$"
        },
        "taskContractDigest": {
          "type": "string",
          "pattern": "^sha256:[a-fA-F0-9]{64}$"
        },
        "allowedActionScopeRefs": {
          "$ref": "#/$defs/refArray"
        },
        "forbiddenActionScopeRefs": {
          "$ref": "#/$defs/refArray"
        },
        "maxAllowedDriftScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "inputLocators": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "inputDigests": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "writeScope": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["resourceType", "resourceKey", "access", "leaseId", "fencingToken", "leaseExpiresAt", "resourceDigestBefore"],
        "properties": {
          "access": {
            "type": "string",
            "const": "write"
          },
          "resourceType": {
            "type": "string",
            "enum": [
              "git_repo",
              "git_worktree",
              "file_path",
              "dir_path",
              "db_schema",
              "db_table",
              "mcp_server",
              "mcp_tool",
              "artifact_path",
              "environment"
            ]
          },
          "resourceKey": {
            "type": "string",
            "minLength": 1
          },
          "leaseId": {
            "type": "string"
          },
          "fencingToken": {
            "type": "integer",
            "minimum": 1
          },
          "leaseExpiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "resourceDigestBefore": {
            "type": "string"
          }
        }
      }
    },
    "repositoryOutputTargetRef": {
      "type": "string",
      "minLength": 1
    },
    "repositoryOutputTargetDigest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "artifactManifestPath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!artifacts/)(?!\\.runtime/)(?!tmp/).+"
    },
    "readScope": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["resourceType", "resourceKey", "access"],
        "properties": {
          "access": {
            "type": "string",
            "const": "read"
          },
          "resourceType": {
            "type": "string"
          },
          "resourceKey": {
            "type": "string",
            "minLength": 1
          },
          "resourceDigest": {
            "type": "string"
          }
        }
      },
      "default": []
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "modelId", "reasoning", "reasoningLevel", "modelDecision", "selectionMode", "modelSelectionDecisionRef"],
      "properties": {
        "model": {
          "type": "string",
          "minLength": 1
        },
        "modelId": {
          "type": "string",
          "minLength": 1
        },
        "alias": {
          "type": "string"
        },
        "providerClass": {
          "type": "string"
        },
        "modelTier": {
          "type": "string",
          "enum": ["standard", "frontier_economy", "frontier_standard", "frontier_plus"]
        },
        "maxModelTier": {
          "type": "string",
          "enum": ["standard", "frontier_economy", "frontier_standard", "frontier_plus"]
        },
        "taskExecutionClass": {
          "type": "string",
          "enum": ["deep_analysis", "implementation", "verification", "short_execution", "mixed_analysis_implementation"]
        },
        "reasoningLevel": {
          "type": "string"
        },
        "reasoning": {
          "type": "string",
          "minLength": 1
        },
        "maxReasoningLevel": {
          "type": "string"
        },
        "modelDecision": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "selectionMode": {
          "type": "string",
          "enum": ["dynamic_context", "auto_best", "auto_fast", "cost_aware"]
        },
        "modelSelectionDecisionRef": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "mcpGrants": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "grantId",
          "projectId",
          "taskGroupId",
          "workId",
          "sessionId",
          "agentNodeId",
          "serverId",
          "toolName",
          "resource",
          "action",
          "schemaDigest",
          "policyDecisionRef",
          "approvalRequestRef",
          "paramPolicyRef",
          "paramPolicyDigest",
          "resultFilterRef",
          "resultFilterDigest",
          "leaseRef",
          "idempotencyKey",
          "riskLevel",
          "issuedAt",
          "expiresAt",
          "maxTtl",
          "grantStatus",
          "revocationRef",
          "auditRef",
          "grantDigest"
        ],
        "properties": {
          "grantId": {
            "type": "string"
          },
          "projectId": {
            "type": "string"
          },
          "taskGroupId": {
            "type": "string"
          },
          "workId": {
            "type": "string"
          },
          "sessionId": {
            "type": "string"
          },
          "agentNodeId": {
            "type": "string"
          },
          "serverId": {
            "type": "string"
          },
          "toolName": {
            "type": "string"
          },
          "resource": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "schemaDigest": {
            "type": "string",
            "pattern": "^sha256:[a-fA-F0-9]{64}$"
          },
          "policyDecisionRef": {
            "type": "string"
          },
          "approvalRequestRef": {
            "type": "string"
          },
          "paramPolicyRef": {
            "type": "string"
          },
          "paramPolicyDigest": {
            "type": "string",
            "pattern": "^sha256:[a-fA-F0-9]{64}$"
          },
          "resultFilterRef": {
            "type": "string"
          },
          "resultFilterDigest": {
            "type": "string",
            "pattern": "^sha256:[a-fA-F0-9]{64}$"
          },
          "leaseRef": {
            "type": "string"
          },
          "idempotencyKey": {
            "type": "string"
          },
          "riskLevel": {
            "type": "string",
            "enum": ["L0", "L1", "L2", "L3"]
          },
          "issuedAt": {
            "type": "string",
            "format": "date-time"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "maxTtl": {
            "type": "string"
          },
          "grantStatus": {
            "type": "string",
            "enum": ["issued", "revoked", "expired"]
          },
          "revocationRef": {
            "type": "string"
          },
          "auditRef": {
            "type": "string"
          },
          "grantDigest": {
            "type": "string",
            "pattern": "^sha256:[a-fA-F0-9]{64}$"
          }
        }
      },
      "default": []
    },
    "permissionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["onMissing", "autoAllowPromptTypes", "denyPromptTypes", "policyDecisionRef"],
      "properties": {
        "onMissing": {
          "type": "string",
          "enum": ["permission_request", "reassign", "scope_reduce", "abort"]
        },
        "autoAllowPromptTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["browser_download", "local_file_picker_read_only", "dev_server_open"]
          },
          "default": []
        },
        "denyPromptTypes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "oauth_consent",
              "account_login",
              "uac_admin",
              "keychain_access",
              "sudo",
              "hardware_key",
              "payment_authorization",
              "cloud_org_boundary",
              "production_boundary"
            ]
          }
        },
        "policyDecisionRef": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "stopOrReturn": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "done",
          "blocked",
          "stale_state",
          "needs_decision",
          "permission_required",
          "spec_drift",
          "failed"
        ]
      }
    },
    "outputContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiredOutputs", "evidenceRequired", "checkpointRequired", "independentReviewRequired", "pushRefRequired"],
      "properties": {
        "requiredOutputs": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["checkpoint", "commitRef", "pushRef", "evidenceRefs", "verificationRefs"]
          }
        },
        "evidenceRequired": {
          "type": "boolean",
          "const": true
        },
        "checkpointRequired": {
          "type": "boolean",
          "const": true
        },
        "independentReviewRequired": {
          "type": "boolean",
          "const": true
        },
        "pushRefRequired": {
          "type": "boolean",
          "const": true
        }
      }
    }
  },
  "allOf": [
    {
      "properties": {
        "outputContract": {
          "properties": {
            "requiredOutputs": {
              "allOf": [
                {
                  "contains": {
                    "const": "checkpoint"
                  }
                },
                {
                  "contains": {
                    "const": "commitRef"
                  }
                },
                {
                  "contains": {
                    "const": "pushRef"
                  }
                },
                {
                  "contains": {
                    "const": "evidenceRefs"
                  }
                },
                {
                  "contains": {
                    "const": "verificationRefs"
                  }
                }
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "writeScope": {
            "contains": {
              "type": "object",
              "properties": {
                "resourceType": {
                  "enum": ["git_repo", "git_worktree", "file_path", "dir_path"]
                }
              },
              "required": ["resourceType"]
            }
          }
        },
        "required": ["writeScope"]
      },
      "then": {
        "required": ["repositoryOutputTargetRef", "repositoryOutputTargetDigest", "artifactManifestPath"]
      }
    }
  ],
  "$defs": {
    "refArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sharedDefinitionRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractRef", "definitionDigest", "status"],
      "properties": {
        "contractRef": {
          "type": "string",
          "minLength": 1
        },
        "definitionDigest": {
          "type": "string",
          "pattern": "^sha256:[a-fA-F0-9]{64}$"
        },
        "status": {
          "type": "string",
          "const": "active"
        }
      }
    }
  }
}
