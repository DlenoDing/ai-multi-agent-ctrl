{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dleno.local/spec/terminal-execution-manifest.schema.json",
  "title": "TerminalExecutionManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "systemId",
    "executionMode",
    "skillRoleSources",
    "modelProviderPolicy",
    "sessionPlacementPolicy",
    "runtimeImprovementPolicy",
    "roleDriftControlPolicy",
    "genericMechanismAssimilationPolicy",
    "parallelExecutionPolicy",
    "reviewPlanningPolicy",
    "runtimeOperationsPolicy",
    "managementConsolePolicy",
    "instructionEfficiencyPolicy",
    "sharedDefinitionPolicy",
    "repositoryOutputPolicy",
    "authorityModel",
    "nonNegotiableInvariants",
    "roles",
    "requiredControlObjects",
    "requiredMachineSpecs",
    "qualityGates",
    "autoGitPolicy",
    "completionContract"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "terminal-execution-manifest/v1"
    },
    "systemId": {
      "type": "string",
      "const": "ai-multi-agent-ctrl"
    },
    "executionMode": {
      "type": "string",
      "const": "ai_agent_autonomous"
    },
    "skillRoleSources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceId", "repositoryUrl", "defaultRef", "pinnedCommit", "catalogFiles", "roleFileGlobs", "trustPolicy", "syncPolicy", "overlayPolicy"],
        "properties": {
          "sourceId": {"type": "string", "minLength": 1},
          "repositoryUrl": {"type": "string"},
          "defaultRef": {"type": "string", "minLength": 1},
          "pinnedCommit": {"type": "string", "pattern": "^[a-fA-F0-9]{40}$"},
          "catalogFiles": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "roleFileGlobs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "trustPolicy": {
            "type": "object",
            "additionalProperties": false,
            "required": ["requirePinnedCommit", "requireFrontmatter", "requireDigestIndex", "allowUnsignedContent"],
            "properties": {
              "requirePinnedCommit": {"type": "boolean", "const": true},
              "requireFrontmatter": {"type": "boolean", "const": true},
              "requireDigestIndex": {"type": "boolean", "const": true},
              "allowUnsignedContent": {"type": "boolean", "const": false}
            }
          },
          "syncPolicy": {
            "type": "object",
            "additionalProperties": false,
            "required": ["mode", "refreshTrigger", "onUpstreamChange"],
            "properties": {
              "mode": {
                "type": "string",
                "enum": ["pinned_snapshot", "tracked_ref_with_digest_gate"]
              },
              "refreshTrigger": {
                "type": "string",
                "enum": ["scheduled_probe", "admin_config_change", "orchestrator_need"]
              },
              "onUpstreamChange": {
                "type": "string",
                "enum": ["create_system_upgrade_candidate", "quarantine_until_verified", "keep_pinned_snapshot"]
              }
            }
          },
          "overlayPolicy": {
            "type": "object",
            "additionalProperties": false,
            "required": ["defaultPrecedence", "allowedScopes", "requiresDecisionRecord", "requiresDigest"],
            "properties": {
              "defaultPrecedence": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["task_group_overlay", "project_overlay", "upstream_default"]
                }
              },
              "allowedScopes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["project", "task_group"]
                }
              },
              "requiresDecisionRecord": {"type": "boolean", "const": true},
              "requiresDigest": {"type": "boolean", "const": true}
            }
          }
        }
      }
    },
    "modelProviderPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registryMode", "providerClasses", "selectionBasis", "decisionObject"],
      "properties": {
        "registryMode": {
          "type": "string",
          "const": "dynamic_provider_capability_probe"
        },
        "providerClasses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/providerClass"
          }
        },
        "selectionBasis": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "decisionObject": {
          "type": "string",
          "const": "ModelSelectionDecision"
        }
      }
    },
    "sessionPlacementPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultPlacement",
        "decisionObject",
        "capacityPolicy",
        "sustainedWorkSignals",
        "shortTaskSignals",
        "placementRules"
      ],
      "properties": {
        "defaultPlacement": {
          "type": "string",
          "const": "new_session_for_sustained_work"
        },
        "decisionObject": {
          "type": "string",
          "const": "SessionPlacementDecision"
        },
        "capacityPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxSubagentsPerControllerSession", "onSubagentLimitApproach"],
          "properties": {
            "maxSubagentsPerControllerSession": {"type": "integer", "minimum": 1},
            "onSubagentLimitApproach": {"type": "string", "const": "start_new_session"}
          }
        },
        "sustainedWorkSignals": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/workSignal"}
        },
        "shortTaskSignals": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/workSignal"}
        },
        "placementRules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ruleId", "placement"],
            "properties": {
              "ruleId": {"type": "string", "minLength": 1},
              "placement": {"type": "string", "enum": ["new_session", "subagent"]},
              "whenAny": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {"$ref": "#/$defs/workSignal"}
              },
              "whenAll": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {"$ref": "#/$defs/workSignal"}
              }
            },
            "anyOf": [
              {"required": ["whenAny"]},
              {"required": ["whenAll"]}
            ]
          }
        }
      }
    },
    "runtimeImprovementPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "candidateObject",
        "issuePatternObject",
        "forbiddenRuntimeActions",
        "collectionTriggers",
        "externalMaintenanceHandoff"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "const": "collect_only_during_project_execution"
        },
        "candidateObject": {
          "type": "string",
          "const": "SystemUpgradeCandidate"
        },
        "issuePatternObject": {
          "type": "string",
          "const": "RuntimeIssuePattern"
        },
        "forbiddenRuntimeActions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "mutate_active_ruleset",
              "self_patch_control_plane",
              "change_scheduler_policy",
              "auto_publish_role_skill_overlay",
              "auto_change_permission_policy",
              "auto_expand_mcp_grant",
              "create_runtime_self_upgrade_task_group",
              "execute_system_upgrade_during_project_run"
            ]
          }
        },
        "collectionTriggers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "repeated_failure_fingerprint",
              "repeated_permission_blocker",
              "repeated_model_selection_failure",
              "repeated_spec_drift",
              "repeated_test_flake",
              "repeated_review_finding",
              "repeated_capacity_blocker",
              "repeated_integration_conflict"
            ]
          }
        },
        "externalMaintenanceHandoff": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "cluster_issue_pattern",
              "create_system_upgrade_candidate",
              "export_upgrade_evidence_package",
              "mark_system_external_maintenance_required",
              "await_system_external_upgrade_import"
            ]
          }
        }
      }
    },
    "roleDriftControlPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "guardObject",
        "effectiveInstructionObject",
        "protectedRoleClasses",
        "requiredFocusLocks",
        "driftSignals",
        "onDrift",
        "metaControlMaxDriftScore",
        "childReboundObject"
      ],
      "properties": {
        "guardObject": {
          "type": "string",
          "const": "RoleDriftGuard"
        },
        "effectiveInstructionObject": {
          "type": "string",
          "const": "EffectiveInstructionPacket"
        },
        "protectedRoleClasses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["meta_control", "control", "monitor"]
          }
        },
        "requiredFocusLocks": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "objective_boundary_digest",
              "role_mission_digest",
              "task_contract_digest",
              "effective_instruction_packet_ref",
              "ruleset_digest",
              "allowed_action_scope",
              "forbidden_action_scope"
            ]
          }
        },
        "driftSignals": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "goal_mismatch",
              "scope_expansion_without_decision",
              "peer_instruction_override",
              "review_result_used_without_local_verification",
              "monitor_alert_unrelated_to_objective",
              "control_loop_repeated_without_progress",
              "missing_completion_readiness",
              "forbidden_action_attempted"
            ]
          }
        },
        "onDrift": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "pause_side_effects",
              "submit_drift_finding",
              "compute_parent_rebound",
              "reissue_task_contract",
              "reassign_role",
              "escalate_to_decision_center",
              "abort_drifted_branch"
            ]
          }
        },
        "metaControlMaxDriftScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.1
        },
        "childReboundObject": {
          "type": "string",
          "const": "DerivedTaskRequest"
        }
      }
    },
    "genericMechanismAssimilationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceClasses", "absorbOnly", "rejectSourceClasses", "decisionObject"],
      "properties": {
        "sourceClasses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["mgp_project_experience", "ai_skills_reference", "external_review_result"]
          }
        },
        "absorbOnly": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "execution_topology",
              "review_planning",
              "derived_task_request",
              "completion_readiness",
              "rule_source_resolution",
              "review_bundle_redaction"
            ]
          }
        },
        "rejectSourceClasses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "project_specific_business_rule",
              "tool_specific_storage_path",
              "archived_rule_as_authority",
              "raw_provider_output_as_authority",
              "non_system_execution_instruction"
            ]
          }
        },
        "decisionObject": {
          "type": "string",
          "const": "RuleSourceResolution"
        }
      }
    },
    "parallelExecutionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topologyObject", "derivedTaskObject", "defaultMergePolicy", "requiredEligibilityGates", "fallbackMode"],
      "properties": {
        "topologyObject": {"type": "string", "const": "ExecutionTopology"},
        "derivedTaskObject": {"type": "string", "const": "DerivedTaskRequest"},
        "defaultMergePolicy": {"type": "string", "const": "parent_serial_after_all_required_reported"},
        "requiredEligibilityGates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "independent_deliverables",
              "owned_paths_disjoint",
              "resource_scopes_disjoint",
              "runner_isolated",
              "result_bundle_contract",
              "parent_serial_merge_owner",
              "final_validation_available"
            ]
          }
        },
        "fallbackMode": {"type": "string", "const": "downgraded_serial"}
      }
    },
    "reviewPlanningPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planObject", "bundleObject", "completionObject", "createPlanWhen", "bundlePolicy"],
      "properties": {
        "planObject": {"type": "string", "const": "ReviewPlan"},
        "bundleObject": {"type": "string", "const": "ReviewBundle"},
        "completionObject": {"type": "string", "const": "CompletionReadinessCheck"},
        "createPlanWhen": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "multi_issue_review",
              "multi_surface_review",
              "high_risk_surface",
              "reviewer_expansion",
              "user_requested_mutual_review",
              "close_gate"
            ]
          }
        },
        "bundlePolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["requireRedaction", "resultIsAdvisory", "requireLocalVerification"],
          "properties": {
            "requireRedaction": {"type": "boolean", "const": true},
            "resultIsAdvisory": {"type": "boolean", "const": true},
            "requireLocalVerification": {"type": "boolean", "const": true}
          }
        }
      }
    },
    "runtimeOperationsPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bootstrapObject", "launchModes", "requiredEntrypoints", "initCommand", "startCommand", "doctorCommand"],
      "properties": {
        "bootstrapObject": {"type": "string", "const": "RuntimeBootstrapProfile"},
        "launchModes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "enum": ["npm", "docker", "shell"]}
        },
        "requiredEntrypoints": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["package.json", "Dockerfile", "docker-compose.yml", "scripts/start.sh"]
          }
        },
        "initCommand": {"type": "string", "const": "npm run init"},
        "startCommand": {"type": "string", "const": "npm start"},
        "doctorCommand": {"type": "string", "const": "npm run doctor"}
      }
    },
    "managementConsolePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["consoleObject", "accountObject", "accessGrantObject", "progressObject", "systemManagementScopes", "userManagementScopes", "guardedActions"],
      "properties": {
        "consoleObject": {"type": "string", "const": "ManagementConsoleSurface"},
        "accountObject": {"type": "string", "const": "Account"},
        "accessGrantObject": {"type": "string", "const": "AccessControlGrant"},
        "progressObject": {"type": "string", "const": "ProgressSnapshot"},
        "systemManagementScopes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["runtime_bootstrap", "system_accounts", "policy_import", "audit_inspection", "external_system_upgrade_import"]
          }
        },
        "userManagementScopes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["project_create", "project_membership", "task_group_control", "agent_activation", "project_progress", "task_group_progress"]
          }
        },
        "guardedActions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "runtime_reinitialize",
              "system_policy_import",
              "external_system_upgrade_import",
              "grant_permission",
              "activate_agent",
              "pause_task_group",
              "resume_task_group",
              "request_task_group_review",
              "rebound_drifted_task"
            ]
          }
        }
      }
    },
    "instructionEfficiencyPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["envelopeObject", "requiredFormatElements", "compressionRules"],
      "properties": {
        "envelopeObject": {"type": "string", "const": "InstructionEnvelope"},
        "requiredFormatElements": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["stable_prefix_digest", "digest_refs", "delta_payload", "output_contract_ref", "cache_key", "token_budget"]
          }
        },
        "compressionRules": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "canonical_rules_by_digest_reference",
              "stable_prefix_before_variable_context",
              "role_specific_delta_only",
              "shared_definition_refs_over_inline_repetition",
              "result_contract_refs_over_freeform_restating"
            ]
          }
        }
      }
    },
    "sharedDefinitionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["definitionObject", "definitionTypes", "ownerRequiredBeforeWork", "producerRequiredBeforePublish", "consumersMustReferenceDigest", "divergenceHandling"],
      "properties": {
        "definitionObject": {"type": "string", "const": "SharedDefinitionContract"},
        "definitionTypes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["terminology", "api_contract", "data_model", "event_schema", "status_semantics", "error_code", "design_token", "quality_standard", "permission_semantics", "instruction_format"]
          }
        },
        "ownerRequiredBeforeWork": {"type": "boolean", "const": true},
        "producerRequiredBeforePublish": {"type": "boolean", "const": true},
        "consumersMustReferenceDigest": {"type": "boolean", "const": true},
        "divergenceHandling": {"type": "string", "const": "block_and_request_canonical_decision"}
      }
    },
    "repositoryOutputPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetObject", "outputPolicy", "targetDecisionOwner", "multiRepositoryDecision", "forbiddenStores", "requiredRefs"],
      "properties": {
        "targetObject": {"type": "string", "const": "RepositoryOutputTarget"},
        "outputPolicy": {"type": "string", "const": "project_git_repository_only"},
        "targetDecisionOwner": {"type": "string", "const": "orchestrator"},
        "multiRepositoryDecision": {"type": "string", "const": "orchestrator_selects_repository_per_work_item"},
        "forbiddenStores": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["separate_file_management_system", "control_plane_blob_store_for_project_outputs", "untracked_local_workspace_as_deliverable"]
          }
        },
        "requiredRefs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["repository_id", "branch", "path_allowlist", "commit_ref", "push_ref_when_remote_required", "artifact_manifest_path"]
          }
        }
      }
    },
    "authorityModel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entryControllerSession", "adminConsole", "orchestrator", "decisionCenter", "policyEngine"],
      "properties": {
        "entryControllerSession": {
          "type": "object",
          "additionalProperties": false,
          "required": ["role", "allowedActions", "forbiddenAsExecutionDependency"],
          "properties": {
            "role": {
              "type": "string",
              "const": "objective_boundary_source"
            },
            "allowedActions": {
              "type": "array",
              "items": {
                "type": "string",
                  "enum": ["submit_objective", "define_boundary", "provide_external_capability_signal"]
              }
            },
            "forbiddenAsExecutionDependency": {
              "type": "boolean",
              "const": true
            }
          }
        },
        "adminConsole": {
          "type": "object",
          "additionalProperties": false,
          "required": ["role", "allowedActions", "forbiddenAsExecutionDependency"],
          "properties": {
            "role": {
              "type": "string",
              "const": "configuration_observation_surface"
            },
            "allowedActions": {
              "type": "array",
              "items": {
                "type": "string",
                  "enum": ["observe_state", "configure_capability_registry", "inspect_audit", "import_external_system_upgrade"]
              }
            },
            "forbiddenAsExecutionDependency": {
              "type": "boolean",
              "const": true
            }
          }
        },
        "orchestrator": {
          "type": "object",
          "additionalProperties": false,
          "required": ["role", "closesTaskGroups", "ownsStateVersion"],
          "properties": {
            "role": {
              "type": "string",
              "const": "canonical_controller"
            },
            "closesTaskGroups": {
              "type": "boolean",
              "const": true
            },
            "ownsStateVersion": {
              "type": "boolean",
              "const": true
            }
          }
        },
        "decisionCenter": {
          "type": "object",
          "additionalProperties": false,
          "required": ["role", "emits"],
          "properties": {
            "role": {
              "type": "string",
              "const": "ai_decision_quorum"
            },
            "emits": {
              "type": "string",
              "const": "DecisionRecord"
            }
          }
        },
        "policyEngine": {
          "type": "object",
          "additionalProperties": false,
          "required": ["role", "blocksUnauthorizedSideEffects"],
          "properties": {
            "role": {
              "type": "string",
              "const": "deterministic_policy_guard"
            },
            "blocksUnauthorizedSideEffects": {
              "type": "boolean",
              "const": true
            }
          }
        }
      }
    },
    "nonNegotiableInvariants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "rule"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "rule": {
            "type": "string",
            "not": {
              "pattern": "[Hh][Uu][Mm][Aa][Nn]|[Mm][Aa][Nn][Uu][Aa][Ll]|[Oo][Pp][Ee][Rr][Aa][Tt][Oo][Rr]|[Pp][Rr][Oo][Jj][Ee][Cc][Tt] [Mm][Aa][Nn][Aa][Gg][Ee][Rr]"
            }
          }
        }
      }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "responsibilities"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "ai_controller",
              "ai_agent_cluster",
              "deterministic_service_with_ai_planner",
              "ai_agent_session",
              "autonomous_service_agent",
              "system_service"
            ]
          },
          "responsibilities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "requiredControlObjects": {
